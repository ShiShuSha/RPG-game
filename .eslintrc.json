{
  "env": {
    "browser": true,
    "node": true,
    "jest": true,
    "es2021": true
  },

  "extends": [
    "airbnb-base"
  ],

  "ignorePatterns": [
    "dist/",
    "coverage/"
  ],

  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },

  "rules": {
    "no-console": "off"
  },

  "overrides": [
    {
      "files": ["webpack.config.js"],
      "env": {
        "node": true
      },
      "parserOptions": {
        "sourceType": "script"
      }
    },
    {
      "files": ["src/js/**/__tests__/*.js", "**/*.test.js"],
      "env": {
        "jest": true
      }
    }
  ]
}